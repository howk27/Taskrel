# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose client-side

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# $19/mo subscription price ID — create in Stripe Dashboard → Products
STRIPE_PRICE_ID=price_...

# ─── Claude AI ────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────────
# NOTE: You need a verified Twilio sender number before SMS will work
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ─── SendGrid (Email) ─────────────────────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@taskrel.com

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
