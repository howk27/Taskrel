# Taskrel environment template
# Copy to .env.local for local development.
# In Vercel, add the production values under Project Settings -> Environment Variables.

# Required for all environments
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for AI quote generation
OPENAI_API_KEY=sk-...
TASKREL_AI_DEFAULT_MODEL=gpt-5.4-mini
TASKREL_AI_COMPLEX_MODEL=gpt-5.5

# Optional: premium unlock codes for complimentary or validation access
# Separate multiple codes with commas. Keep these server-side only.
TASKREL_PREMIUM_ACCESS_CODES=friend-test-2026,owner-demo

# Optional: property value verification for pricing intelligence
RENTCAST_API_KEY=your-rentcast-api-key

# Required for quote/invoice email sending
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Required for public client quote links, approvals, and Stripe webhook status updates
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: SMS sending
# Leave unset until Twilio is ready. Missing Twilio keys no longer block email sends.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Required for public paid launch: Stripe billing, client payment links, and payment status updates
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Optional: Google Sheets sync
# Production redirect URI:
# https://your-vercel-domain.com/api/google-sheets/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# PDF rendering (headless Chromium)
# Local dev: point PUPPETEER_EXECUTABLE_PATH at a local Chrome/Chromium binary.
PUPPETEER_EXECUTABLE_PATH=/path/to/chrome
# Production/serverless ONLY: the @sparticuz/chromium pack tarball. Do NOT set
# this locally — the renderer prefers it and will download the pack instead of
# using the local binary above. Keep the version in sync with
# @sparticuz/chromium-min in package.json.
# NOTE: Vercel/Lambda is x86_64, so the asset is ...-pack.x64.tar (a bare
# ...-pack.tar does not exist and 404s, which fails PDF generation silently).
# CHROMIUM_PACK_URL=https://github.com/Sparticuz/chromium/releases/download/v149.0.0/chromium-v149.0.0-pack.x64.tar

# Optional: suppress known Serwist + Turbopack warning noise
SERWIST_SUPPRESS_TURBOPACK_WARNING=1
