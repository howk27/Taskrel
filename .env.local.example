# Taskrel environment template
# Copy to .env.local for local development.
# In Vercel, add the production values under Project Settings -> Environment Variables.

# Required for all environments
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for AI quote generation
OPENAI_API_KEY=sk-...
TASKREL_AI_DEFAULT_MODEL=gpt-5.4-mini
TASKREL_AI_COMPLEX_MODEL=gpt-5.5

# Optional: closed-test premium unlock codes
# Separate multiple codes with commas. Keep these server-side only.
TASKREL_PREMIUM_ACCESS_CODES=friend-test-2026,owner-demo

# Required for quote/invoice email sending
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Optional: Supabase admin operations
# Not currently required by the app runtime, but useful if future admin routes need it.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: SMS sending
# Leave unset until Twilio is ready. Missing Twilio keys no longer block email sends.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Optional: Stripe billing and client payment links
# Closed testing can run without these unless you want subscription/payments live.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Optional: Google Sheets sync
# Production redirect URI:
# https://your-vercel-domain.com/api/google-sheets/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: suppress known Serwist + Turbopack warning noise
SERWIST_SUPPRESS_TURBOPACK_WARNING=1
